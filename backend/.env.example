# App
NODE_ENV=production
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=https://autoflow.vercel.app

# Database - REQUIRED
# Runtime: use Supabase pooler for the app. Add ?pgbouncer=true&connection_limit=1 when using transaction pooling.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?pgbouncer=true&connection_limit=1
# Optional but recommended for Prisma migrations on Render: use the direct NodeJS/Postgres connection from Supabase.
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres

# JWT - REQUIRED
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-for-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-for-production
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Meta / Instagram
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
# Alias supported in code:
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
INSTAGRAM_ACCESS_TOKEN=your-instagram-graph-api-access-token

# AI / LLMs
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
AI_AUTO_REPLY_ENABLED=true

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-domain.com/auth/google/callback

# Logging Level
LOG_LEVEL=log
